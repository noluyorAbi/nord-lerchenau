# Postgres
DATABASE_URI=postgres://svnord:svnord_dev@localhost:5432/svnord

# Payload
PAYLOAD_SECRET=replace-with-32-char-random-string

# Public site URL (used by Payload for asset paths and revalidation)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Internal: token used by Payload afterChange hooks to call /api/revalidate.
# Used in P4. Set to any random string for dev.
REVALIDATE_SECRET=dev-revalidate-secret

# Resend — leave empty in dev (submissions still save to Payload)
# INTERIM (2026-07-06): FROM sendet von verifizierter Domain adatepe.dev,
# da svnord.de noch nicht in Resend verifiziert ist. TODO: Vereins-Resend-Konto
# + svnord.de per DNS verifizieren, dann FROM auf kontakt@svnord.de umstellen.
RESEND_API_KEY=
RESEND_FROM_EMAIL=SV Nord Kontakt <kontakt@adatepe.dev>
RESEND_TO_EMAIL=info@svnord.de

# Vercel Blob — leave empty in dev (uploads land in public/uploads/)
# Set in production to enable blob storage for Media uploads.
BLOB_READ_WRITE_TOKEN=

# OpenAI key for /api/chat (Nord-Assistent)
OPENAI_API_KEY=
# optional override, defaults to gpt-4o-mini
OPENAI_MODEL=
